// Asigns the spawned ship a number based on current Reserve count
switch (obj_RescueEvent.FriendShipCount)
{
	case 1:
		FriendShipNumber = 1;
		break;
	case 2:
		FriendShipNumber = 2;
		break
	case 3:
		FriendShipNumber = 3;
		break;
}
